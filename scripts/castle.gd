class_name Castle
extends RefCounted

# ---------------------------------------------------------------------------
# 定数
# ---------------------------------------------------------------------------
const MAX_HP: int = 20

# 城のデフォルト配置（0始まり座標）
# 設計書「縦-横」1始まり → Vector2i(col-1, row-1)
#   player: 6-3, 6-4 → Vector2i(2,5), Vector2i(3,5)
#   enemy:  1-3, 1-4 → Vector2i(2,0), Vector2i(3,0)
const PLAYER_CELLS: Array = [Vector2i(2, 5), Vector2i(3, 5)]
const ENEMY_CELLS:  Array = [Vector2i(2, 0), Vector2i(3, 0)]

# ---------------------------------------------------------------------------
# プロパティ
# ---------------------------------------------------------------------------
var owner: String           # "player" or "enemy"
var hp:    int = MAX_HP
var cells: Array[Vector2i]  # この城が占有するマス（2マス）

# ---------------------------------------------------------------------------
# コンストラクタ
# ---------------------------------------------------------------------------
func _init(p_owner: String) -> void:
	owner = p_owner
	cells.assign(PLAYER_CELLS if p_owner == "player" else ENEMY_CELLS)


# ---------------------------------------------------------------------------
# ダメージ処理
# ---------------------------------------------------------------------------
func take_damage(amount: int) -> void:
	hp = max(0, hp - amount)


# ---------------------------------------------------------------------------
# 判定
# ---------------------------------------------------------------------------
func is_destroyed() -> bool:
	return hp <= 0


func contains(pos: Vector2i) -> bool:
	return pos in cells


# ---------------------------------------------------------------------------
# デバッグ用
# ---------------------------------------------------------------------------
func _to_string() -> String:
	return "[Castle owner=%s hp=%d/%d cells=%s]" % [owner, hp, MAX_HP, cells]
